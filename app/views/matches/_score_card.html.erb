<% is_active        = player == match.current_player %>
<% avg              = match.three_dart_average(player) %>
<% score            = match.score_for(player) %>
<% pct              = [(501 - score) * 100 / 501, 0].max %>
<% sets_won         = match.sets_won_by(player) %>
<% legs_won         = match.current_set&.legs_won_by(player) || 0 %>
<% multi_set        = match.best_of_sets > 1 %>
<% multi_leg        = match.best_of_legs > 1 %>
<% darts_thrown = is_active ? (match.current_leg&.current_turn&.throws&.count || 0) : 0 %>
<% suggestion   = CheckoutCalculator.suggest(score, darts_remaining: 3 - darts_thrown) %>

<%# Last completed turn %>
<% last_turn = if match.current_leg
                 match.current_leg.turns
                      .where(player_id: player.id)
                      .where.not(completed_at: nil)
                      .order(completed_at: :desc)
                      .first
               end %>
<% last_turn_total  = last_turn&.total_score %>
<% last_turn_throws = last_turn_total ? [] : match.last_turn_throws_for(player) %>
<% last_turn_ids    = last_turn_throws.map(&:id) %>
<% prev_throws      = last_turn_total ? [] : match.last_throws_for(player, limit: 6)
                                                  .reject { |t| last_turn_ids.include?(t.id) }
                                                  .first(3) %>

<div id="score-card-<%= player.id %>"
     class="score-card rounded-xl overflow-hidden <%= is_active ? "active-player" : "" %>">

  <div class="flex items-start justify-between gap-3 px-4 pt-4 pb-3">

    <%# Left: name + score + checkout + sets/legs %>
    <div class="flex-shrink-0 min-w-0">

      <%# Name + throwing indicator %>
      <p class="text-zinc-600 text-xs mono tracking-widest uppercase mb-1 flex items-center gap-2">
        <%= player.display_name %>
        <% if player.guest? %><span class="text-zinc-800">(guest)</span><% end %>
        <% if is_active %>
          <span style="font-family:'DM Mono',monospace;font-size:0.55rem;color:#ef4444;
                       letter-spacing:0.12em;animation:pulse-text 1.5s ease-in-out infinite">
            ▶ THROWING
          </span>
        <% end %>
      </p>

      <%# Score %>
      <p id="player-<%= player.id %>-score"
         class="score-display <%= is_active ? "active-player" : "" %>">
        <%= score %>
      </p>

      <%# Checkout suggestion %>
      <% if suggestion %>
        <div class="flex items-center gap-1 flex-wrap mt-1">
          <% suggestion.each_with_index do |throw, i| %>
            <span style="font-family:'DM Mono',monospace;font-size:0.55rem;
                         padding:1px 5px;border-radius:3px;white-space:nowrap;
                         background:<%= throw.start_with?('T') ? '#1e3a5f' :
                                         throw.start_with?('D') || throw == 'Bull' ? '#7f1d1d' :
                                         '#1a1a1a' %>;
                         color:<%= throw.start_with?('T') ? '#93c5fd' :
                                     throw.start_with?('D') || throw == 'Bull' ? '#fca5a5' :
                                     '#777' %>;
                         border:1px solid <%= throw.start_with?('T') ? '#1d4ed8' :
                                               throw.start_with?('D') || throw == 'Bull' ? '#991b1b' :
                                               '#2a2a2a' %>">
              <%= throw %>
            </span>
            <% if i < suggestion.size - 1 %>
              <span style="color:#2a2a2a;font-size:0.5rem">→</span>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%# Sets / legs counters %>
      <% if multi_set || multi_leg %>
        <div class="flex items-center gap-2 mt-1">
          <% if multi_set %>
            <div style="font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.1em">
              <span style="color:#444;text-transform:uppercase">Sets </span>
              <span style="font-family:'Bebas Neue',sans-serif;font-size:1rem;
                           color:<%= sets_won > 0 ? '#ef4444' : '#333' %>">
                <%= sets_won %>
              </span>
            </div>
            <div style="width:1px;height:12px;background:#2a2a2a"></div>
          <% end %>
          <% if multi_leg %>
            <div style="font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.1em">
              <span style="color:#444;text-transform:uppercase">Legs </span>
              <span style="font-family:'Bebas Neue',sans-serif;font-size:1rem;
                           color:<%= legs_won > 0 ? '#ef4444' : '#333' %>">
                <%= legs_won %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Right: avg + turn score %>
    <% show_right = last_turn_total || last_turn_throws.any? || prev_throws.any? %>
    <% if show_right %>
      <div class="flex flex-col items-end gap-1.5 flex-shrink-0">

        <%# Average %>
        <div class="flex items-baseline gap-1">
          <span style="font-family:'DM Mono',monospace;font-size:0.5rem;
                       letter-spacing:0.12em;color:#333;text-transform:uppercase">avg</span>
          <span style="font-family:'Bebas Neue',sans-serif;font-size:1.4rem;line-height:1;
                       color:<%= avg >= 60 ? '#22c55e' : avg >= 40 ? '#f59e0b' : '#555' %>">
            <%= avg %>
          </span>
        </div>

        <%# Total mode — show single number %>
        <% if last_turn_total %>
          <span style="font-family:'Bebas Neue',sans-serif;font-size:1.6rem;line-height:1;
                       color:#ddd">
            <%= last_turn_total %>
          </span>

        <%# Single mode — show throw badges %>
        <% elsif last_turn_throws.any? %>
          <div class="flex items-center gap-1">
            <% last_turn_throws.each do |t| %>
              <span style="font-family:'DM Mono',monospace;font-size:0.65rem;
                           padding:2px 6px;border-radius:3px;
                           <%= t.multiplier == 'double' ? 'background:#7f1d1d;color:#fca5a5;border:1px solid #991b1b' :
                               t.multiplier == 'triple' ? 'background:#1e3a5f;color:#93c5fd;border:1px solid #1d4ed8' :
                               t.multiplier == 'miss'   ? 'background:#1a1010;color:#444;border:1px solid #2a1a1a' :
                               'background:#222;color:#ddd;border:1px solid #3a3a3a' %>">
                <%= t.multiplier == 'miss' ? '✕' : t.multiplier == 'single' ? '' : t.multiplier[0].upcase %><%= t.multiplier == 'miss' ? '' : t.segment %>
              </span>
            <% end %>
            <% (3 - last_turn_throws.size).times do %>
              <span style="font-family:'DM Mono',monospace;font-size:0.65rem;
                           padding:2px 6px;border-radius:3px;
                           background:#111;color:#222;border:1px solid #1a1a1a">—</span>
            <% end %>
          </div>

          <%# Previous turn — dimmed %>
          <% if prev_throws.any? %>
            <div class="flex items-center gap-1" style="opacity:0.25">
              <% prev_throws.each do |t| %>
                <span style="font-family:'DM Mono',monospace;font-size:0.5rem;
                             padding:1px 3px;border-radius:2px;
                             <%= t.multiplier == 'double' ? 'background:#7f1d1d;color:#fca5a5;border:1px solid #991b1b' :
                                 t.multiplier == 'triple' ? 'background:#1e3a5f;color:#93c5fd;border:1px solid #1d4ed8' :
                                 'background:#1a1a1a;color:#555;border:1px solid #222' %>">
                  <%= t.multiplier == 'single' ? '' : t.multiplier[0].upcase %><%= t.segment %>
                </span>
              <% end %>
            </div>
          <% end %>
        <% end %>

      </div>
    <% end %>

  </div>

  <%# Progress bar %>
  <div class="mx-4 mb-3 h-px rounded-full overflow-hidden bg-zinc-900">
    <div id="player-<%= player.id %>-progress"
         class="h-full rounded-full transition-all duration-500"
         style="width:<%= pct %>%;background:<%= is_active ? '#dc2626' : '#3f3f46' %>">
    </div>
  </div>

  <%# Sets/legs pip track %>
  <% if multi_set || multi_leg %>
    <div class="px-4 pb-3 flex items-center gap-1.5">
      <% count = multi_set ? match.best_of_sets : match.best_of_legs %>
      <% won   = multi_set ? sets_won : legs_won %>
      <% count.times do |i| %>
        <div style="width:8px;height:8px;border-radius:50%;
                    background:<%= i < won ? '#dc2626' : '#1e1e1e' %>;
                    border:1px solid <%= i < won ? '#ef4444' : '#2a2a2a' %>;
                    transition:background 0.2s ease">
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="pb-1"></div>
  <% end %>

</div>
