<div
  data-controller="keyboard"
  data-keyboard-url-value="<%= turn_throws_path(turn) %>"
  data-keyboard-score-value="<%= match.score_for(match.current_player) %>"
  data-keyboard-player-id-value="<%= match.current_player.id %>">

  <%# Player indicators %>
  <div class="flex gap-3 mb-6">
    <% match.players.each do |player| %>
      <% is_active = player == match.current_player %>
      <div class="flex-1 px-4 py-3 rounded-xl border transition-all duration-200
        <%= is_active ?
            "bg-red-950/50 border-red-700 shadow-[0_0_20px_rgba(220,38,38,0.15)]" :
            "bg-zinc-900/50 border-zinc-800" %>">
        <div class="flex items-center justify-between">
          <span class="mono text-xs tracking-widest uppercase
            <%= is_active ? "text-red-400" : "text-zinc-600" %>">
            <%= player.display_name %>
            <% if player.guest? %>
              <span class="opacity-50">(guest)</span>
            <% end %>
          </span>
          <% if is_active %>
            <span class="mono text-xs text-red-600 tracking-widest"
                  style="animation: pulse-text 1.5s ease-in-out infinite">▶ UP</span>
          <% else %>
            <span class="mono text-xs text-zinc-700">WAITING</span>
          <% end %>
        </div>
        <p class="bebas text-2xl mt-1 <%= is_active ? "text-red-400" : "text-zinc-600" %>">
          <%= match.score_for(player) %>
        </p>
      </div>
    <% end %>
  </div>

  <%# Mode toggle — inside controller div so modeLabel target is in scope %>
  <div class="flex items-center gap-3 mb-4">
    <button type="button"
            data-action="click->keyboard#toggleMode"
            class="flex items-center gap-2 bg-zinc-900 border border-zinc-800 rounded-lg px-3 py-2
                   hover:border-zinc-600 transition-all">
      <div class="relative w-8 h-4 bg-zinc-700 rounded-full transition-colors"
           id="mode-track">
        <div class="absolute top-0.5 left-0.5 w-3 h-3 bg-white rounded-full transition-transform"
             id="mode-thumb"></div>
      </div>
      <span data-keyboard-target="modeLabel"
            class="mono text-xs text-zinc-500 tracking-widest">SINGLE THROW</span>
    </button>
  </div>

  <%# Score preview %>
  <p class="mono text-xs text-zinc-600 tracking-widest uppercase mb-2">PREVIEW</p>
  <p data-keyboard-target="score"
     class="bebas text-5xl text-red-500 tabular-nums leading-none mb-4">
    <%= match.score_for(match.current_player) %>
  </p>

  <%# Input %>
  <input type="text"
         data-keyboard-target="input"
         data-action="input->keyboard#preview keydown->keyboard#handle"
         placeholder="20  d20  t20  b  db"
         class="throw-input w-full px-4 py-3 rounded-lg text-lg mb-3"
         autocomplete="off">

  <%# Undo — only useful in single mode %>
  <button type="button"
          data-action="click->keyboard#undoLastThrow"
          class="btn-undo px-4 py-2 rounded-lg mt-2">
    ↩ UNDO
  </button>

</div>

<%# Hidden form — found by id so can live outside controller div %>
<%= form_with url: turn_throws_path(turn),
              method: :post,
              data: { turbo_stream: true },
              html: { id: "keyboard-form" } do |f| %>
  <%= f.hidden_field :segment,    name: "throw[segment]",    id: "keyboard-segment" %>
  <%= f.hidden_field :multiplier, name: "throw[multiplier]", id: "keyboard-multiplier" %>
  <%= f.hidden_field :total,      name: "throw[total]",      id: "keyboard-total" %>
<% end %>
