<div
  data-controller="keyboard"
  data-keyboard-url-value="<%= turn_throws_path(turn) %>"
  data-keyboard-score-value="<%= match.score_for(match.current_player) %>"
  data-keyboard-player-id-value="<%= match.current_player.id %>">

  <%# Mode toggle + Undo on same row %>
  <div class="flex items-center justify-between gap-3 mb-4">
    <button type="button"
            data-action="click->keyboard#toggleMode"
            class="flex items-center gap-2 bg-zinc-900 border border-zinc-800 rounded-lg px-3 py-2
                   hover:border-zinc-600 transition-all">
      <div class="relative w-8 h-4 bg-zinc-700 rounded-full transition-colors"
           id="mode-track">
        <div class="absolute top-0.5 left-0.5 w-3 h-3 bg-white rounded-full transition-transform"
             id="mode-thumb"></div>
      </div>
      <span data-keyboard-target="modeLabel"
            class="mono text-xs text-zinc-500 tracking-widest">SINGLE THROW</span>
    </button>
    <button type="button"
            data-action="click->keyboard#undoLastThrow"
            class="btn-undo px-4 py-2 rounded-lg">
      ↩ UNDO
    </button>
  </div>

  <%# Input %>
  <input type="text"
         data-keyboard-target="input"
         data-action="input->keyboard#preview keydown->keyboard#handle"
         placeholder="20  d20  t20  b  db"
         class="throw-input w-full px-4 py-3 rounded-lg text-lg"
         autocomplete="off">

</div>

<%# Hidden form %>
<%= form_with url: turn_throws_path(turn),
              method: :post,
              data: { turbo_stream: true },
              html: { id: "keyboard-form" } do |f| %>
  <%= f.hidden_field :segment,    name: "throw[segment]",    id: "keyboard-segment" %>
  <%= f.hidden_field :multiplier, name: "throw[multiplier]", id: "keyboard-multiplier" %>
  <%= f.hidden_field :total,      name: "throw[total]",      id: "keyboard-total" %>
<% end %>
