<div id="finish-popup-overlay"
     style="position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:100;
            display:flex;align-items:center;justify-content:center;
            backdrop-filter:blur(4px)">

  <div style="background:#111;border:1px solid #2a2a2a;border-top:2px solid #22c55e;
              border-radius:16px;padding:2rem;max-width:380px;width:90%;
              box-shadow:0 0 60px rgba(34,197,94,0.15)">

    <%# Winner header %>
    <div class="text-center mb-6">
      <p style="font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.2em;
                color:#16a34a;text-transform:uppercase;margin-bottom:8px">
        Checkout
      </p>
      <p style="font-family:'Bebas Neue',sans-serif;font-size:2.5rem;line-height:1;
                color:#4ade80;letter-spacing:0.05em">
        <%= player.display_name %>
      </p>
      <p style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#555;margin-top:4px">
        wins the leg
      </p>
    </div>

    <%# Throws input %>
    <%= form_with url: leg_checkout_path(leg), method: :patch,
          data: { turbo_stream: true },
          html: { id: "checkout-form" } do |f| %>

      <div class="mb-5">
        <p style="font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.15em;
                  color:#444;text-transform:uppercase;margin-bottom:10px;text-align:center">
          How many darts to finish?
        </p>

        <%# Quick select buttons: 1 2 3 %>
        <div class="flex gap-2 mb-3">
          <% [1, 2, 3].each do |n| %>
            <button type="button"
                    onclick="document.getElementById('checkout-throws-input').value = <%= n %>; document.querySelectorAll('.dart-count-btn').forEach(b => b.classList.remove('active')); this.classList.add('active')"
                    class="dart-count-btn flex-1 py-3 rounded-lg border transition-all"
                    style="font-family:'Bebas Neue',sans-serif;font-size:1.4rem;
                           background:#0a0a0a;border-color:#2a2a2a;color:#555;
                           cursor:pointer;transition:all 0.15s ease"
                    onmouseover="this.style.borderColor='#22c55e';this.style.color='#4ade80'"
                    onmouseout="if(!this.classList.contains('active')){this.style.borderColor='#2a2a2a';this.style.color='#555'}">
              <%= n %>
            </button>
          <% end %>
        </div>

        <style>
          .dart-count-btn.active {
            background: #052e16 !important;
            border-color: #16a34a !important;
            color: #4ade80 !important;
          }
        </style>

        <%= f.hidden_field :checkout_throws, id: "checkout-throws-input", value: "" %>
      </div>

      <div class="flex gap-2">
        <%= f.submit "CONFIRM →",
              style: "flex:1;font-family:'Bebas Neue',sans-serif;font-size:1rem;
                      letter-spacing:0.1em;background:#16a34a;color:white;
                      border:1px solid #22c55e;border-radius:8px;padding:12px;
                      cursor:pointer;transition:all 0.15s ease",
              onmouseover: "this.style.background='#22c55e'",
              onmouseout:  "this.style.background='#16a34a'" %>

        <button type="button"
                onclick="document.getElementById('finish-popup').innerHTML = ''"
                style="font-family:'DM Mono',monospace;font-size:0.65rem;letter-spacing:0.1em;
                       background:none;border:1px solid #2a2a2a;color:#444;border-radius:8px;
                       padding:12px 16px;cursor:pointer;transition:all 0.15s ease"
                onmouseover="this.style.borderColor='#555';this.style.color='#888'"
                onmouseout="this.style.borderColor='#2a2a2a';this.style.color='#444'">
          SKIP
        </button>
      </div>

    <% end %>
  </div>
</div>
