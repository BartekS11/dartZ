<% match       = leg.match %>
<% multi_set   = match.best_of_sets > 1 %>
<% multi_leg   = match.best_of_legs > 1 %>
<% set_winner  = multi_set && leg.match_set.finished? && leg.match_set.winner == player %>
<% match_won   = match.finished? && match.winner == player %>

<% if multi_set %>
  <% sets_won = match.sets_won_by(player) %>
  <% legs_won = leg.match_set.legs_won_by(player) %>
<% elsif multi_leg %>
  <% legs_won = leg.match_set&.legs_won_by(player) || 0 %>
<% end %>

<div id="finish-popup-overlay"
     style="position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:100;
            display:flex;align-items:center;justify-content:center;
            backdrop-filter:blur(4px)">

  <div style="background:#111;border:1px solid #2a2a2a;
              border-top:2px solid <%= match_won ? '#ef4444' : set_winner ? '#f59e0b' : '#22c55e' %>;
              border-radius:16px;padding:2rem;max-width:380px;width:90%;
              box-shadow:0 0 60px rgba(<%= match_won ? '220,38,38' : set_winner ? '245,158,11' : '34,197,94' %>,0.15)">

    <div class="text-center mb-6">

      <%# Context label %>
      <p style="font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.2em;
                color:<%= match_won ? '#ef4444' : set_winner ? '#f59e0b' : '#16a34a' %>;
                text-transform:uppercase;margin-bottom:8px">
        <% if match_won %>
          🏆 Match Won
        <% elsif set_winner %>
          Set Won
        <% else %>
          🎯 Checkout
        <% end %>
      </p>

      <%# Player name %>
      <p style="font-family:'Bebas Neue',sans-serif;font-size:2.5rem;line-height:1;
                color:<%= match_won ? '#ef4444' : set_winner ? '#f59e0b' : '#4ade80' %>;
                letter-spacing:0.05em">
        <%= player.display_name %>
      </p>

      <%# Subtitle %>
      <p style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#555;margin-top:4px">
        <% if match_won %>
          wins the match
        <% elsif set_winner %>
          wins the set
        <% else %>
          wins the leg
        <% end %>
      </p>

      <%# Sets/legs score %>
      <% if multi_set %>
        <div style="margin-top:12px;display:flex;align-items:center;justify-content:center;gap:16px">
          <% match.players.each_with_index do |p, i| %>
            <div style="text-align:center">
              <p style="font-family:'DM Mono',monospace;font-size:0.55rem;color:#333;
                        letter-spacing:0.1em;margin-bottom:2px"><%= p.display_name %></p>
              <p style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;line-height:1;
                        color:<%= match.winner == p ? '#ef4444' : '#333' %>">
                <%= match.sets_won_by(p) %>
              </p>
            </div>
            <% if i == 0 %>
              <span style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#2a2a2a">—</span>
            <% end %>
          <% end %>
        </div>
      <% elsif multi_leg %>
        <div style="margin-top:12px;display:flex;align-items:center;justify-content:center;gap:16px">
          <% match.players.each_with_index do |p, i| %>
            <div style="text-align:center">
              <p style="font-family:'DM Mono',monospace;font-size:0.55rem;color:#333;
                        letter-spacing:0.1em;margin-bottom:2px"><%= p.display_name %></p>
              <p style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;line-height:1;
                        color:<%= leg.match_set&.legs_won_by(p).to_i > 0 ? '#ef4444' : '#333' %>">
                <%= leg.match_set&.legs_won_by(p) || 0 %>
              </p>
            </div>
            <% if i == 0 %>
              <span style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#2a2a2a">—</span>
            <% end %>
          <% end %>
        </div>
      <% end %>

    </div>

    <%# Throws input — only show if match not over %>
    <% unless match_won %>
      <%= form_with url: leg_checkout_path(leg), method: :patch,
            data: { turbo_stream: true },
            html: { id: "checkout-form" } do |f| %>

        <div class="mb-5">
          <p style="font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.15em;
                    color:#444;text-transform:uppercase;margin-bottom:10px;text-align:center">
            How many darts to finish?
          </p>

          <div class="flex gap-2 mb-3">
            <% [1, 2, 3].each do |n| %>
              <button type="button"
                      onclick="document.getElementById('checkout-throws-input').value = <%= n %>;
                               document.querySelectorAll('.dart-count-btn').forEach(b => b.classList.remove('active'));
                               this.classList.add('active')"
                      class="dart-count-btn flex-1 py-3 rounded-lg border"
                      style="font-family:'Bebas Neue',sans-serif;font-size:1.4rem;
                             background:#0a0a0a;border-color:#2a2a2a;color:#555;
                             cursor:pointer;transition:all 0.15s ease"
                      onmouseover="this.style.borderColor='#22c55e';this.style.color='#4ade80'"
                      onmouseout="if(!this.classList.contains('active')){this.style.borderColor='#2a2a2a';this.style.color='#555'}">
                <%= n %>
              </button>
            <% end %>
          </div>

          <style>
            .dart-count-btn.active {
              background: #052e16 !important;
              border-color: #16a34a !important;
              color: #4ade80 !important;
            }
          </style>

          <%= f.hidden_field :checkout_throws, id: "checkout-throws-input", value: "" %>
        </div>

        <div class="flex gap-2">
          <%= f.submit "NEXT LEG →",
                style: "flex:1;font-family:'Bebas Neue',sans-serif;font-size:1rem;
                        letter-spacing:0.1em;background:#16a34a;color:white;
                        border:1px solid #22c55e;border-radius:8px;padding:12px;
                        cursor:pointer;transition:all 0.15s ease",
                onmouseover: "this.style.background='#22c55e'",
                onmouseout:  "this.style.background='#16a34a'" %>

          <button type="button"
                  onclick="document.getElementById('finish-popup').innerHTML = ''"
                  style="font-family:'DM Mono',monospace;font-size:0.65rem;letter-spacing:0.1em;
                         background:none;border:1px solid #2a2a2a;color:#444;border-radius:8px;
                         padding:12px 16px;cursor:pointer;transition:all 0.15s ease"
                  onmouseover="this.style.borderColor='#555';this.style.color='#888'"
                  onmouseout="this.style.borderColor='#2a2a2a';this.style.color='#444'">
            SKIP
          </button>
        </div>

      <% end %>
    <% else %>
      <%# Match is over — just dismiss %>
<button type="button"
        onclick="this.closest('#finish-popup-overlay').style.display='none'"
        style="width:100%;font-family:'Bebas Neue',sans-serif;font-size:1rem;
               letter-spacing:0.1em;background:#dc2626;color:white;
               border:1px solid #ef4444;border-radius:8px;padding:12px;
               cursor:pointer">
  SEE RESULTS →
</button>
    <% end %>

  </div>
</div>
