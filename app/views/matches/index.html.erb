<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap');

  .dart-bg {
    background-color: #0a0a0a;
    background-image:
      radial-gradient(circle at 20% 50%, rgba(185,28,28,0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(185,28,28,0.05) 0%, transparent 40%),
      repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.02) 39px, rgba(255,255,255,0.02) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.02) 39px, rgba(255,255,255,0.02) 40px);
    min-height: 100vh;
    font-family: 'DM Sans', sans-serif;
  }

  .match-card {
    background: linear-gradient(135deg, #141414 0%, #1a1a1a 100%);
    border: 1px solid #2a2a2a;
    border-left: 3px solid #dc2626;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .match-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(135deg, rgba(220,38,38,0.05) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .match-card:hover {
    border-color: #dc2626;
    border-left-color: #ef4444;
    transform: translateX(4px);
    box-shadow: -4px 0 20px rgba(220,38,38,0.2);
  }

  .match-card:hover::before { opacity: 1; }

  .btn-primary {
    background: #dc2626;
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 0.1em;
    font-size: 1rem;
    transition: all 0.15s ease;
    border: 1px solid #ef4444;
  }

  .btn-primary:hover {
    background: #ef4444;
    box-shadow: 0 0 20px rgba(220,38,38,0.4);
    transform: translateY(-1px);
  }

  .match-id {
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 0.05em;
  }

  .mono { font-family: 'DM Mono', monospace; }
</style>

<div class="dart-bg px-4 py-10">
  <div class="max-w-2xl mx-auto">

    <%# Header %>
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-1 bg-red-600"></div>
        <span class="text-red-600 text-xs tracking-widest uppercase mono">dartZ</span>
      </div>
      <h1 style="font-family: 'Bebas Neue', sans-serif; font-size: 3.5rem; line-height: 1; color: #f5f5f5; letter-spacing: 0.02em;">
        Your Matches
      </h1>
      <p class="text-zinc-500 text-sm mt-2">Track your 501 sessions</p>
    </div>

    <%# New Match Button %>
    <%= button_to matches_path, method: :post,
          class: "btn-primary w-full text-white py-3 px-6 rounded mb-8 block text-center" do %>
      + NEW MATCH
    <% end %>

<%# Match List %>
<% if @matches.any? %>
  <div class="space-y-3">
    <% @matches.order(created_at: :desc).each_with_index do |match, i| %>
      <%= link_to match_path(match), class: "match-card rounded-lg p-4 flex items-center justify-between block" do %>
        <div class="flex items-center gap-4">
          <span class="text-zinc-600 mono text-xs w-6 text-right"><%= i + 1 %></span>
          <div>
            <p class="match-id text-white text-xl">Match #<%= match.id %></p>
            <p class="text-zinc-500 text-xs mono"><%= match.created_at.strftime("%d %b %Y · %H:%M") %></p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <% if match.finished? %>
            <span class="text-xs text-red-400 border border-red-900 bg-red-950 px-2 py-0.5 rounded mono">FINISHED</span>
          <% else %>
            <span class="text-xs text-green-400 border border-green-900 bg-green-950 px-2 py-0.5 rounded mono">LIVE</span>
          <% end %>
          <span class="text-red-500 text-sm mono font-medium tracking-wider">OPEN →</span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
      <div class="text-center py-20 border border-dashed border-zinc-800 rounded-lg">
        <p class="text-zinc-600 text-sm">No matches yet.</p>
        <p class="text-zinc-700 text-xs mt-1">Create one to get started.</p>
      </div>
    <% end %>

  </div>
</div>
