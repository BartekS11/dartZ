<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap');

  .dart-bg {
    background-color: #0a0a0a;
    background-image:
      radial-gradient(circle at 20% 50%, rgba(185,28,28,0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(185,28,28,0.05) 0%, transparent 40%),
      repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.02) 39px, rgba(255,255,255,0.02) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.02) 39px, rgba(255,255,255,0.02) 40px);
    min-height: 100vh;
    font-family: 'DM Sans', sans-serif;
  }

  .match-card {
    background: linear-gradient(135deg, #141414 0%, #1a1a1a 100%);
    border: 1px solid #2a2a2a;
    border-left: 3px solid #dc2626;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    display: block;
  }

  .match-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(135deg, rgba(220,38,38,0.05) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .match-card:hover {
    border-color: #dc2626;
    border-left-color: #ef4444;
    transform: translateX(4px);
    box-shadow: -4px 0 20px rgba(220,38,38,0.2);
  }

  .match-card:hover::before { opacity: 1; }

  .btn-primary {
    background: #dc2626;
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 0.1em;
    font-size: 1rem;
    transition: all 0.15s ease;
    border: 1px solid #ef4444;
  }

  .btn-primary:hover {
    background: #ef4444;
    box-shadow: 0 0 20px rgba(220,38,38,0.4);
    transform: translateY(-1px);
  }

  .match-id {
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 0.05em;
  }

  .mono { font-family: 'DM Mono', monospace; }

  .player-score-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .player-score-name {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: #555;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .player-score-name.winner {
    color: #f5f5f5;
    font-weight: 500;
  }

  .player-score-val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.1rem;
    color: #3a3a3a;
    letter-spacing: 0.04em;
    min-width: 36px;
    text-align: right;
  }

  .player-score-val.winner {
    color: #ef4444;
  }

  .player-score-val.active {
    color: #888;
  }

  .winner-crown {
    font-size: 0.65rem;
    margin-right: 2px;
  }

  .progress-bar-track {
    height: 2px;
    background: #1e1e1e;
    border-radius: 2px;
    overflow: hidden;
    margin-top: 2px;
  }

  .progress-bar-fill {
    height: 100%;
    border-radius: 2px;
    background: #3a3a3a;
    transition: width 0.3s ease;
  }

  .progress-bar-fill.winner { background: #dc2626; }
</style>

<%# data-controller on outermost div so all targets are in scope %>
<div class="dart-bg px-4 py-10" data-controller="lobby">
  <div class="max-w-2xl mx-auto">

    <%# Header %>
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-1 bg-red-600"></div>
        <span class="text-red-600 text-xs tracking-widest uppercase mono">dartZ</span>
      </div>
      <h1 style="font-family: 'Bebas Neue', sans-serif; font-size: 3.5rem; line-height: 1; color: #f5f5f5; letter-spacing: 0.02em;">
        Your Matches
      </h1>
      <p class="text-zinc-500 text-sm mt-2">Track your 501 sessions</p>
    </div>

    <%# Returning players greeting %>
    <div id="greeting-wrapper" class="hidden text-center mb-6">
      <p class="mono text-xs text-zinc-600 tracking-widest mb-1">LAST PLAYERS</p>
      <p data-lobby-target="greeting"
         style="font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: 0.08em;"
         class="text-zinc-400"></p>
    </div>

    <%# New Match Form %>
    <%= form_with url: matches_path, method: :post, data: { turbo: false, action: "submit->lobby#save" } do |f| %>
      <div class="flex gap-3 mb-4">

        <div class="flex-1 bg-zinc-900 border border-zinc-800 border-t-2 border-t-red-700 rounded-xl p-4">
          <p class="mono text-xs text-zinc-600 tracking-widest mb-2 text-center">PLAYER 1</p>
          <%= f.text_field :player1_name,
                placeholder: "Enter name",
                maxlength: 20,
                autocomplete: "off",
                data: { lobby_target: "player1", action: "input->lobby#save" },
                class: "w-full bg-zinc-950 border border-zinc-800 text-white text-center
                        font-mono text-sm px-3 py-2 rounded-lg
                        focus:outline-none focus:border-red-600" %>
        </div>

        <div class="flex items-center justify-center px-1">
          <span style="font-family: 'Bebas Neue', sans-serif;" class="text-2xl text-red-700 opacity-60">VS</span>
        </div>

        <div class="flex-1 bg-zinc-900 border border-zinc-800 border-t-2 border-t-red-700 rounded-xl p-4">
          <p class="mono text-xs text-zinc-600 tracking-widest mb-2 text-center">PLAYER 2</p>
          <%= f.text_field :player2_name,
                placeholder: "Enter name",
                maxlength: 20,
                autocomplete: "off",
                data: { lobby_target: "player2", action: "input->lobby#save" },
                class: "w-full bg-zinc-950 border border-zinc-800 text-white text-center
                        font-mono text-sm px-3 py-2 rounded-lg
                        focus:outline-none focus:border-red-600" %>
        </div>

      </div>

      <%= f.submit "START MATCH →",
            class: "btn-primary w-full text-white py-3 px-6 rounded mb-8 block text-center cursor-pointer" %>
    <% end %>

    <%# Match list header %>
    <p class="mono text-xs text-zinc-700 tracking-widest uppercase mb-3">Recent Matches</p>

    <%# Logged-in user — server-rendered matches %>
    <% if Current.user && @matches.any? %>
      <div class="space-y-3">
        <% @matches.order(created_at: :desc).limit(10).each_with_index do |match, i| %>
          <% winner = match.winner %>
          <%= link_to match_path(match), class: "match-card rounded-lg p-4" do %>
            <div class="flex items-start justify-between gap-4">

              <%# Left: match meta %>
              <div class="flex items-center gap-3 min-w-0">
                <span class="text-zinc-700 mono text-xs w-5 text-right flex-shrink-0"><%= i + 1 %></span>
                <div class="min-w-0">
                  <p class="match-id text-zinc-500 text-base">Match #<%= match.id %></p>
                  <p class="text-zinc-700 text-xs mono"><%= match.created_at.strftime("%d %b · %H:%M") %></p>
                </div>
              </div>

              <%# Right: player scores %>
              <div class="flex-shrink-0 min-w-[140px] space-y-1.5">
                <% match.players.each do |player| %>
                  <% is_winner = winner && winner == player %>
                  <% score = match.score_for(player) %>
                  <% pct = [ (501 - score) * 100 / 501, 0 ].max %>
                  <div>
                    <div class="player-score-row">
                      <span class="player-score-name <%= is_winner ? "winner" : "" %>">
                        <% if is_winner %>
                          <span class="winner-crown">🎯</span>
                        <% end %>
                        <%= player.display_name %>
                      </span>
                      <span class="player-score-val <%= is_winner ? "winner" : (match.finished? ? "" : "active") %>">
                        <%= score %>
                      </span>
                    </div>
                    <div class="progress-bar-track">
                      <div class="progress-bar-fill <%= is_winner ? "winner" : "" %>"
                           style="width: <%= pct %>%"></div>
                    </div>
                  </div>
                <% end %>
              </div>

              <%# Status badge %>
              <div class="flex-shrink-0 flex flex-col items-end gap-1">
                <% if match.finished? %>
                  <span class="text-xs text-red-400 border border-red-900 bg-red-950 px-2 py-0.5 rounded mono">FINISHED</span>
                <% else %>
                  <span class="text-xs text-green-400 border border-green-900 bg-green-950 px-2 py-0.5 rounded mono">LIVE</span>
                <% end %>
                <span class="text-red-600 text-xs mono">OPEN →</span>
              </div>

            </div>
          <% end %>
        <% end %>
      </div>

    <%# Guest — match list injected from localStorage by lobby_controller %>
    <% else %>
<div data-lobby-target="matchList" class="space-y-3">
        <%# Rendered by lobby_controller#renderMatchList %>
  </div>
    <% end %>

  </div>
</div>
