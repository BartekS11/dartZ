<style>
  .auth-input {
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    background: #111;
    border: 1px solid #2a2a2a;
    color: #f5f5f5;
    padding: 12px 16px;
    border-radius: 6px;
    width: 100%;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    letter-spacing: 0.05em;
  }

  .auth-input:focus {
    outline: none;
    border-color: #dc2626;
    box-shadow: 0 0 0 2px rgba(220,38,38,0.15);
  }

  .auth-input::placeholder { color: #3a3a3a; }

  .auth-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: #555;
    display: block;
    margin-bottom: 6px;
  }

  .btn-signin {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.1em;
    background: #dc2626;
    color: #fff;
    border: 1px solid #ef4444;
    padding: 10px 32px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s ease;
    width: 100%;
  }

  .btn-signin:hover {
    background: #ef4444;
    box-shadow: 0 0 20px rgba(220,38,38,0.35);
    transform: translateY(-1px);
  }

  .auth-card {
    background: linear-gradient(135deg, #111, #161616);
    border: 1px solid #222;
    border-top: 2px solid #dc2626;
    border-radius: 12px;
    padding: 2.5rem;
  }

  .forgot-link {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: #444;
    text-decoration: none;
    border-bottom: 1px solid #333;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .forgot-link:hover { color: #dc2626; border-color: #dc2626; }
</style>

<div class="min-h-[70vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md">

    <%# Header %>
    <div class="mb-8 text-center">
      <div class="flex items-center justify-center gap-2 mb-2">
        <div class="w-6 h-px bg-red-700"></div>
        <span class="mono text-red-700 text-xs tracking-widest">WELCOME BACK</span>
        <div class="w-6 h-px bg-red-700"></div>
      </div>
      <h1 class="bebas text-4xl text-white tracking-wider">Sign In</h1>
      <p class="mono text-zinc-600 text-xs mt-1 tracking-wide">Ready to throw?</p>
    </div>

    <div class="auth-card">

      <%# Alert %>
      <% if alert = flash[:alert] %>
        <div class="mono text-xs text-red-400 border border-red-900 bg-red-950 rounded px-4 py-3 mb-6 tracking-wide">
          ⚠ <%= alert %>
        </div>
      <% end %>

      <%# Notice %>
      <% if notice = flash[:notice] %>
        <div class="mono text-xs text-green-400 border border-green-900 bg-green-950 rounded px-4 py-3 mb-6 tracking-wide">
          ✓ <%= notice %>
        </div>
      <% end %>

      <%= form_with url: session_url, class: "space-y-5" do |form| %>

        <div>
          <label class="auth-label">EMAIL ADDRESS</label>
          <%= form.email_field :email_address,
                required: true,
                autofocus: true,
                autocomplete: "username",
                placeholder: "Enter your email address",
                value: params[:email_address],
                class: "auth-input" %>
        </div>

        <div>
          <label class="auth-label">PASSWORD</label>
          <%= form.password_field :password,
                required: true,
                autocomplete: "current-password",
                placeholder: "Enter your password",
                maxlength: 72,
                class: "auth-input" %>
        </div>

        <div class="pt-2 space-y-4">
          <%= form.submit "SIGN IN", class: "btn-signin" %>

          <div class="text-center">
            <%= link_to "Forgot password?", new_password_path, class: "forgot-link" %>
          </div>
        </div>

      <% end %>
    </div>

  </div>
</div>
