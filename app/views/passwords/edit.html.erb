<style>
  .auth-input {
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    background: #111;
    border: 1px solid #2a2a2a;
    color: #f5f5f5;
    padding: 12px 16px;
    border-radius: 6px;
    width: 100%;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    letter-spacing: 0.05em;
  }

  .auth-input:focus {
    outline: none;
    border-color: #dc2626;
    box-shadow: 0 0 0 2px rgba(220,38,38,0.15);
  }

  .auth-input::placeholder { color: #3a3a3a; }

  .auth-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: #555;
    display: block;
    margin-bottom: 6px;
  }

  .btn-save {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.1em;
    background: #dc2626;
    color: #fff;
    border: 1px solid #ef4444;
    padding: 10px 32px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s ease;
    width: 100%;
  }

  .btn-save:hover {
    background: #ef4444;
    box-shadow: 0 0 20px rgba(220,38,38,0.35);
    transform: translateY(-1px);
  }

  .auth-card {
    background: linear-gradient(135deg, #111, #161616);
    border: 1px solid #222;
    border-top: 2px solid #dc2626;
    border-radius: 12px;
    padding: 2.5rem;
  }
</style>

<div class="min-h-[70vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md">

    <%# Header %>
    <div class="mb-8 text-center">
      <div class="flex items-center justify-center gap-2 mb-2">
        <div class="w-6 h-px bg-red-700"></div>
        <span class="mono text-red-700 text-xs tracking-widest">ACCOUNT</span>
        <div class="w-6 h-px bg-red-700"></div>
      </div>
      <h1 class="bebas text-4xl text-white tracking-wider">Update Password</h1>
      <p class="mono text-zinc-600 text-xs mt-1 tracking-wide">Choose a strong new password</p>
    </div>

    <div class="auth-card">

      <%# Alert %>
      <% if alert = flash[:alert] %>
        <div class="mono text-xs text-red-400 border border-red-900 bg-red-950 rounded px-4 py-3 mb-6 tracking-wide">
          ⚠ <%= alert %>
        </div>
      <% end %>

      <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-5" do |form| %>

        <div>
          <label class="auth-label">NEW PASSWORD</label>
          <%= form.password_field :password,
                required: true,
                autocomplete: "new-password",
                placeholder: "Enter new password",
                maxlength: 72,
                class: "auth-input" %>
        </div>

        <div>
          <label class="auth-label">CONFIRM PASSWORD</label>
          <%= form.password_field :password_confirmation,
                required: true,
                autocomplete: "new-password",
                placeholder: "Repeat new password",
                maxlength: 72,
                class: "auth-input" %>
        </div>

        <div class="pt-2">
          <%= form.submit "SAVE PASSWORD", class: "btn-save" %>
        </div>

      <% end %>
    </div>

  </div>
</div>
